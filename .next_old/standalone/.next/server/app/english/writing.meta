{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/english/layout,_N_T_/english/writing/layout,_N_T_/english/writing/page,_N_T_/english/writing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/english/writing/__PAGE__",
    "/english/writing",
    "/english",
    "/_index",
    "/_head"
  ]
}