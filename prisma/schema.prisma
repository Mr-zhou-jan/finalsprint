// FinalSprint V1 — Prisma Schema
// 对齐评审建议 + 保留提分系统化字段

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========== 用户与考试项目 ==========

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String?
  avatarUrl  String?
  quotaUsed  Int       @default(0)
  quotaLimit Int       @default(300)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
  questionAttempts QuestionAttempt[]
  wrongQuestions    WrongQuestion[]
}

model Project {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  subjectName   String
  examDate      DateTime
  targetScore   Int
  currentLevel  String   // zero | weak | average
  dailyMinutes  Int      // 每日可用分钟
  goalType      String   @default("pass") // pass | score_boost
  status        String   @default("active") // active | archived | completed
  predictedMin  Int?
  predictedMax  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examScope        ExamScope?
  modules          SubjectModule[]
  materials        Material[]
  examPoints       ExamPoint[]
  diagnosticRuns   DiagnosticRun[]
  sprintPlan       SprintPlan?
  practiceSessions PracticeSession[]
  aiTasks          AiTask[]
  wrongQuestions   WrongQuestion[]
}

// ========== 课程结构与知识点 ==========

model SubjectModule {
  id                  String   @id @default(uuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId            String?  // 支持树状章节
  parent              SubjectModule? @relation("ModuleTree", fields: [parentId], references: [id])
  children            SubjectModule[] @relation("ModuleTree")
  title               String
  description         String?
  orderIndex          Int      @default(0)
  estimatedScoreValue Float?   // 该章节预计占分
  priorityLevel       Int?     // 1-5
  masteryStatus       String   @default("unknown")
  createdAt           DateTime @default(now())

  examPoints ExamPoint[]
}

model ExamPoint {
  id                String       @id @default(uuid())
  projectId         String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId          String?
  module            SubjectModule? @relation(fields: [moduleId], references: [id])
  title             String
  summary           String?
  // 考试价值层
  estimatedScoreMin Float?
  estimatedScoreMax Float?
  hitRate           Float?       // 出现概率 0~1
  avgStudyMinutes   Int?         // 学习耗时
  roiScore          Float?       // 提分性价比
  targetTier        String?      // pass | 75 | 85 | all
  importanceTier    String?      // must | important | optional | skip
  // 内容层
  formulas          Json?
  commonPatterns    Json?        // 高频题型
  solvingTemplate   Json?
  traps             Json?
  sourceEvidence    Json?
  // 掌握状态
  masteryStatus     String       @default("unknown")
  confidenceScore   Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  practiceQuestions PracticeQuestion[]
  studyTasks        StudyTask[]
  materialMaps      MaterialExamPointMap[]
}

model ExamScope {
  id               String   @id @default(uuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType       String   // user_material | manual_input | ai_inferred | hybrid | default_pack
  title            String
  chapterTree      Json     // [{chapter, topics[], weight}]
  overallCoverage  Float?   // 0~1
  pointCoverageMap Json?    // [{pointId, covered, sourceMaterialIds[], confidence}]
  createdAt        DateTime @default(now())
}

// ========== 学习资料 ==========

model Material {
  id               String    @id @default(uuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  resourceType     String    @default("pdf") // pdf | ppt | image | past_exam | notes | video_link | text
  sourceUrl        String?
  storagePath      String?
  rawText          String?
  parseStatus      String    @default("pending") // pending | parsing | success | failed
  extractedText    String?
  extractionJson   Json?
  sourceMeta       Json?     // {platform, url, duration, author}
  parsedTranscript Json?
  compressedNotes  Json?     // CrashSummary
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  examPointMaps    MaterialExamPointMap[]
  parseJobs        AiTask[]
}

model MaterialExamPointMap {
  id          String   @id @default(uuid())
  materialId  String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  examPointId String
  examPoint   ExamPoint @relation(fields: [examPointId], references: [id], onDelete: Cascade)
  confidence  Float?
  sourceChunk String?
  createdAt   DateTime @default(now())

  @@unique([materialId, examPointId])
}

// ========== 题目系统 ==========

model PracticeQuestion {
  id          String    @id @default(uuid())
  projectId   String
  examPointId String
  examPoint   ExamPoint @relation(fields: [examPointId], references: [id], onDelete: Cascade)
  type        String    // single | multi | fill | short_answer | calculation
  difficulty  Int       // 1-5
  source      String    // generated | uploaded | past_exam
  stem        String
  options     Json?
  answer      Json
  explanation Json?
  scoreValue  Int       @default(5)
  createdAt   DateTime  @default(now())

  attempts       QuestionAttempt[]
  wrongQuestions WrongQuestion[]
}

model QuestionAttempt {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  projectId   String
  questionId  String
  question    PracticeQuestion @relation(fields: [questionId], references: [id])
  sessionId   String?
  session     PracticeSession? @relation(fields: [sessionId], references: [id])
  userAnswer  Json
  isCorrect   Boolean
  errorType   String?   // concept | formula | careless | no_idea | half_understood
  aiFeedback  String?
  wrongQuestion WrongQuestion?
  createdAt   DateTime  @default(now())
}

model PracticeSession {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mode           String   // diagnostic | point_practice | daily_plan | mock_exam
  status         String   @default("in_progress")
  totalQuestions Int
  correctCount   Int?
  resultJson     Json?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  createdAt      DateTime @default(now())

  attempts QuestionAttempt[]
}

// ========== 诊断系统 ==========

model DiagnosticRun {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String   @default("摸底诊断")
  status            String   @default("generated") // generated | submitted | graded
  generatedFrom     String   @default("generic_subject_based") // resource_based | generic_subject_based
  totalQuestions    Int
  correctCount      Int
  predictedMin      Int?
  predictedMax      Int?
  paperSnapshot     Json
  answerSnapshot    Json?
  gradingSnapshot   Json?
  weakOpportunities Json?
  riskReport        Json?
  createdAt         DateTime @default(now())
}

// ========== 提分计划 ==========

model SprintPlan {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version         Int      @default(1)
  planType        String   @default("pass_60") // pass_60 | target_70 | target_80 | sprint
  targetTier      String   // pass | 75 | 85
  totalDays       Int
  dailyMinutes    Int
  status          String   @default("active")
  strategySummary Json?
  startScore      Int?
  targetScore     Int
  latestPredScore Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks StudyTask[]
}

model StudyTask {
  id               String    @id @default(uuid())
  projectId        String
  planId           String
  plan             SprintPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  examPointId      String?
  examPoint        ExamPoint? @relation(fields: [examPointId], references: [id])
  moduleId         String?
  dayIndex         Int        @default(1)
  title            String
  taskType         String     // learn | practice | review | mock_exam | memorize
  priority         Int        @default(3)
  estimatedMinutes Int
  expectedGain     Float?
  status           String     @default("todo") // todo | doing | done | skipped
  sourceReason     String?
  planVersion      Int        @default(1)
  isLocked         Boolean    @default(false)
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
}

// ========== 错题本 ==========

model WrongQuestion {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionId      String
  question        PracticeQuestion @relation(fields: [questionId], references: [id])
  attemptId       String    @unique
  attempt         QuestionAttempt @relation(fields: [attemptId], references: [id])
  errorReason     String?   // concept | formula | careless | no_idea
  recommendedAction String? // 建议动作
  status          String    @default("active") // active | resolved
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
}

// ========== AI 异步任务 ==========

model AiTask {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialId      String?
  material        Material? @relation(fields: [materialId], references: [id])
  type            String   // material_parse | material_compress | exam_point_extract | diagnostic_generate | diagnostic_grade | sprint_plan_generate | risk_report_generate
  idempotencyKey  String?
  status          String   @default("pending") // pending | running | success | failed
  inputJson       Json?
  outputJson      Json?
  errorMessage    String?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
