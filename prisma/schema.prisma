generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String?
  avatarUrl  String?
  quotaUsed  Int       @default(0)
  quotaLimit Int       @default(300)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
}

model Project {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  subjectName   String
  examDate      DateTime
  targetScore   Int
  currentLevel  String
  dailyMinutes  Int
  status        String   @default("active")
  predictedMin  Int?
  predictedMax  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examScope         ExamScope?
  materials         Material[]
  examPoints        ExamPoint[]
  diagnosticRuns    DiagnosticRun[]
  sprintPlan        SprintPlan?
  practiceSessions  PracticeSession[]
  aiTasks           AiTask[]
}

model Material {
  id               String    @id @default(uuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  type             String    // pdf | text | past_exam | video_link
  sourceType       String    @default("pdf") // pdf | text | video_link | past_exam
  sourceMeta       Json?     // {platform, url, duration, author} for video links
  fileUrl          String?
  rawText          String?
  parsedTranscript Json?     // segmented subtitles for video links
  compressedNotes  Json?     // CrashSummary: {sections[{title,examPoints,mustRemember,commonTraps,skipable}],finalCheatSheet}
  status           String    @default("pending")
  extractedText    String?
  extractionJson   Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  examPointMaps    MaterialExamPointMap[]
}

model ExamPoint {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  chapterTitle      String?
  summary           String?
  // 考试价值层
  estimatedScoreMin Float?   // 最低贡献分
  estimatedScoreMax Float?   // 最高贡献分
  hitRate           Float?   // 出现概率 0~1
  avgStudyMinutes   Int?     // 从0到能做题，大概多久
  roiScore          Float?   // 提分性价比 = (分值×概率×薄弱度)/耗时
  targetTier        String?  // pass | 75 | 85 | all
  importanceTier    String?  // must | important | optional | skip
  // 内容层
  formulas          Json?
  commonPatterns    Json?
  solvingTemplate   Json?
  traps             Json?
  sourceEvidence    Json?
  // 掌握状态
  masteryStatus     String   @default("unknown")
  confidenceScore   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceQuestions   PracticeQuestion[]
  studyTasks          StudyTask[]
  materialMaps        MaterialExamPointMap[]
}

model ExamScope {
  id               String   @id @default(uuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType       String   // user_material | manual_input | ai_inferred | hybrid
  title            String
  chapterTree      Json     // [{chapter, topics[], weight}]
  overallCoverage  Float?   // 总覆盖度 0~1
  pointCoverageMap Json?    // [{pointId, covered, sourceMaterialIds[], confidence}]
  createdAt        DateTime @default(now())
}

model MaterialExamPointMap {
  id          String   @id @default(uuid())
  materialId  String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  examPointId String
  examPoint   ExamPoint @relation(fields: [examPointId], references: [id], onDelete: Cascade)
  confidence  Float?   // 该考点来自这份资料的置信度
  sourceChunk String?  // 来自资料的哪一段
  createdAt   DateTime @default(now())

  @@unique([materialId, examPointId])
}

model DiagnosticRun {
  id               String   @id @default(uuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status           String   @default("generated") // generated | submitted | graded
  totalQuestions   Int
  correctCount     Int
  predictedMin     Int?
  predictedMax     Int?
  paperSnapshot    Json     // 本次诊断卷完整题目快照
  answerSnapshot   Json?    // 用户答案快照
  gradingSnapshot  Json?    // 逐题评分明细
  weakOpportunities Json?   // 本次生成的机会点列表
  riskReport       Json?    // 风险报告
  createdAt        DateTime @default(now())
}

model SprintPlan {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetTier      String   // pass | 75 | 85
  totalDays        Int
  status          String   @default("active")
  strategySummary Json?    // 策略摘要（文字描述+关键数据）
  startScore      Int?     // 初始诊断估分
  targetScore     Int
  latestPredScore Int?     // 最新预测分
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks           StudyTask[]
}

model StudyTask {
  id               String   @id @default(uuid())
  projectId        String
  planId           String
  plan             SprintPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  examPointId      String?
  examPoint        ExamPoint? @relation(fields: [examPointId], references: [id])
  date             DateTime
  title            String
  taskType         String    // learn | practice | review | mock
  priority         Int       @default(3) // 1-5
  estimatedMinutes Int       // 预计耗时
  expectedGain     Float?    // 预计提分
  status           String    @default("todo") // todo | doing | done | skipped
  sourceReason     String?   // weak_point | high_roi | exam_hotspot | error_retry | coverage_gap
  planVersion      Int       @default(1)  // 计划版本号
  isLocked         Boolean   @default(false) // 锁定后重算不会改动
  completedAt      DateTime?
  createdAt        DateTime @default(now())
}

model PracticeQuestion {
  id          String    @id @default(uuid())
  projectId   String
  examPointId String
  examPoint   ExamPoint @relation(fields: [examPointId], references: [id], onDelete: Cascade)
  type        String
  difficulty  Int
  source      String
  stem        String
  options     Json?
  answer      Json
  explanation Json?
  createdAt   DateTime  @default(now())
}

model PracticeSession {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mode           String
  status         String   @default("completed")
  totalQuestions Int
  correctCount   Int?
  resultJson     Json?
  createdAt      DateTime @default(now())
}

model AiTask {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            String   // material_extract | material_compress | exam_point_extract | diagnostic_generate | diagnostic_grade | sprint_plan_generate | risk_report_generate
  idempotencyKey  String?  // 幂等键：防止重复提交
  status          String   @default("pending") // pending | running | success | failed
  inputJson       Json?
  outputJson      Json?
  errorMessage    String?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
